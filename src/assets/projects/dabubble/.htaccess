<IfModule mod_mime.c>
  AddType audio/mp4 .m4a
  AddType video/mp4 .mp4 .m4v
  AddType application/font-woff .woff
  AddType application/font-woff2 .woff2
  AddType application/vnd.ms-fontobject .eot
  AddType font/ttf .ttf
  AddType font/otf .otf
  AddEncoding gzip .svgz
  AddType image/svg+xml .svg
  <FilesMatch "\.svg$">
    AddType "image/svg+xml" .svg
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /dabubble/
  
  # Don't rewrite if it's a real file or directory
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # Don't rewrite static files
  RewriteCond %{REQUEST_URI} \.(js|css|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|otf|ico)$ [NC]
  RewriteRule ^ - [L]
  
  # Rewrite everything else to index.html for SPA routing
  RewriteRule ^ /dabubble/index.html [L]
</IfModule>